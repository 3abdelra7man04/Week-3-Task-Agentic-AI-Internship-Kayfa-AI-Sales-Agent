# ---------------------- APP Config ----------------------
APP_NAME="RAG-APP"
APP_VERSION="0.1"

# ---------------------- FILES Config ----------------------
FILE_ALLOWED_TYPES=["text/plain", "application/pdf"]
FILE_MAX_SIZE=10 # 10 MB
FILE_DEFAULT_CHUNK_SIZE=512000 # 512KB
FILE_IMAGES_MAX_WIDTH=600
FILE_IMAGES_DPI=200

# ---------------------- DB Config ----------------------
MONGODB_URL="mongodb+srv://<username>:<password>@<cluster-url>/"
MONGODB_DATABASE="Kayfa_Sales_Agent"
CHAT_DOCUMENT_TTL=600

# ---------------------- LLM Config ----------------------
AGENT_BACKEND="openai"
EXTRACTION_BACKEND="openai"
GENERATION_BACKEND="openai"
EMBEDDING_BACKEND="openai"
RERANKING_BACKEND="cohere"

OPENROUTER_API_KEY="sk-or-v1-..."
OPENAI_API_KEY="sk-or-v1-..."
OPENAI_API_URL="https://openrouter.ai/api/v1"
COHERE_API_KEY="your-cohere-api-key"

AGENT_MODEL_ID="google/gemini-3-flash-preview"
EXTRACTION_MODEL_ID="google/gemini-3-flash-preview"
GENERATION_MODEL_ID="google/gemini-3-flash-preview"
EMBEDDING_MODEL_ID="openai/text-embedding-3-large"
EMBEDDING_MODEL_SIZE=3072
RERANKING_MODEL_ID="rerank-v3.5"

EXTRACTION_MAX_OUTPUT_TOKENS=8192
INPUT_MAX_CHARACTERS=2048    
GENERATION_OUTPUT_MAX_TOKENS=2048
GENERATION_TEMPERATURE=0.3

# ---------------------- VectorDB Config ----------------------
VECTOR_DB_BACKEND="qdrant"
VECTOR_DB_URL="https://your-qdrant-cluster-url.cloud.qdrant.io"
VECTOR_DB_API_KEY="your-qdrant-api-key"
VECTOR_DB_PATH="qdrant_db"
VECTOR_DB_DISTANCE_METHOD="cosine"

# ---------------------- Template Config ----------------------
PRIMARY_LANG="ar"
DEFAULT_LANG="ar"
